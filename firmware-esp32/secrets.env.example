# Copy this file to `secrets.env` and fill in your values.
# `secrets.env` is gitignored; build.rs reads it and bakes the values in at
# compile time via env!(). Missing keys build fine but won't connect.

WIFI_SSID=your-wifi-ssid
WIFI_PASSWORD=your-wifi-password

# Home Assistant MQTT broker (plaintext, port 1883). HA_USER/HA_TOKEN are the
# MQTT username/password (e.g. a Mosquitto user, or HA's MQTT integration user).
HA_HOST=homeassistant.local
HA_USER=mqtt-user
HA_TOKEN=mqtt-password
